include({{ os.path.join(profile_dir, "gcc15") }})

[settings]
arch=x86_64

[conf]
tools.build:cflags=["-march=skylake"]
tools.build:cxxflags=["-march=skylake"]
tools.build.cross_building:can_run=true
batmat/*:tools.cmake.cmaketoolchain:extra_variables*={"CMAKE_UNITY_BUILD": "On"}
batmat/*:tools.cmake.cmaketoolchain:extra_variables*={"CMAKE_UNITY_BUILD_BATCH_SIZE": "4"}

[options]
openblas/*:target=HASWELL
blasfeo/*:target=X64_INTEL_HASWELL
